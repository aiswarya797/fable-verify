{
  "name": "agent-audits",
  "version": "0.1.1",
  "description": "Repo-local proof-of-done loops for AI coding agents with acceptance criteria, evidence reviews, JSON checks, and audit reports.",
  "homepage": "https://github.com/aiswarya797/agent-audits#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiswarya797/agent-audits.git"
  },
  "bugs": {
    "url": "https://github.com/aiswarya797/agent-audits/issues"
  },
  "license": "MIT",
  "bin": {
    "agent-audits": "bin/agent-audits"
  },
  "files": [
    "assets",
    "bin/agent-audits",
    "docs",
    "examples",
    "agent-audits/SKILL.md",
    "agent_audits/__init__.py",
    "agent_audits/cli.py",
    "LICENSE",
    "README.md",
    "scripts/doctor.py",
    "scripts/eval_matrix.py",
    "scripts/realistic_demo.py",
    "scripts/smoke_test.py"
  ],
  "keywords": [
    "agents",
    "agent-audit",
    "agent-verification",
    "ai-agent",
    "ai-agents",
    "ai-coding-agent",
    "coding-agent",
    "coding-agents",
    "verification",
    "proof-of-done",
    "acceptance-criteria",
    "audit-trail",
    "completion-receipt",
    "pr-gate",
    "pr-verification",
    "github-actions",
    "ci",
    "json-output",
    "codex",
    "claude",
    "claude-code",
    "cursor",
    "opencode",
    "evidence",
    "audit",
    "proof-gate"
  ],
  "scripts": {
    "test": "python3 -B -m unittest discover -s tests",
    "doctor": "python3 -B scripts/doctor.py",
    "smoke": "python3 -B scripts/smoke_test.py",
    "demo:realistic": "python3 -B scripts/realistic_demo.py",
    "eval:matrix": "python3 -B scripts/eval_matrix.py",
    "pack:check": "npm pack --dry-run",
    "preflight": "npm test && npm run doctor && npm run smoke && npm run eval:matrix && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  }
}
